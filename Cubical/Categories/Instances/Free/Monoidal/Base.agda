  module _ (MŠīį : MonoidalCategoryŠīį FreeMonoidalCategory ‚ĄďC ‚ĄďC') where
    private
      module MŠīį = MonoidalCategoryŠīį MŠīį
    module _ (ńĪ : ‚ąÄ (x : X) ‚Üí MŠīį.ob[ ‚ÜĎ x ]) where

      elim-ob : ‚ąÄ x ‚Üí MŠīį.ob[ x ]
      elim-ob (‚ÜĎ x) = ńĪ x
      elim-ob unit = MŠīį.unitŠīį
      elim-ob (x ‚äó y) = elim-ob x MŠīį.‚äóŠīį elim-ob y

      elim-hom : ‚ąÄ {x y}(f : |FreeMonoidalCategory| [ x , y ])
        ‚Üí MŠīį.Hom[ f ][ elim-ob x , elim-ob y ]
      elim-hom id‚āĎ = MŠīį.idŠīį
      elim-hom (f ‚čÜ‚āĎ g) = elim-hom f MŠīį.‚čÜŠīį elim-hom g
      elim-hom (‚čÜ‚āĎIdL f i) = MŠīį.‚čÜIdLŠīį (elim-hom f) i
      elim-hom (‚čÜ‚āĎIdR f i) = MŠīį.‚čÜIdRŠīį (elim-hom f) i
      elim-hom (‚čÜ‚āĎAssoc f g h i) =
        MŠīį.‚čÜAssocŠīį (elim-hom f)(elim-hom g)(elim-hom h) i
      elim-hom (isSetHom‚āĎ f g p q i j) =
        isSetHomŠīį' MŠīį.CŠīį
          (elim-hom f) (elim-hom g)
          (cong elim-hom p) (cong elim-hom q)
          i j
      elim-hom (f ‚äó g) = elim-hom f MŠīį.‚äó‚āēŠīį elim-hom g
      elim-hom (‚äóid i) = MŠīį.‚ĒÄ‚äóŠīį‚ĒÄ .F-idŠīį i
      elim-hom (‚äó‚čÜ f g f' g' i) =
        MŠīį.‚ĒÄ‚äóŠīį‚ĒÄ .F-seqŠīį
          ((elim-hom f) , (elim-hom f'))
          (elim-hom g , elim-hom g')
          i
      elim-hom őĪ = MŠīį.őĪŠīį‚ü® _ , _ , _ ‚ü©
      elim-hom (őĪ-nat f g h i) =
        MŠīį.őĪŠīį .transŠīį .N-homŠīį ((elim-hom f) , (elim-hom g) , (elim-hom h)) i
      elim-hom őĪ‚ĀĽ = MŠīį.őĪŠīį .nIsoŠīį _ .invŠīį
      elim-hom (őĪ‚čÜőĪ‚ĀĽ i) = MŠīį.őĪŠīį .nIsoŠīį _ .retŠīį i
      elim-hom (őĪ‚ĀĽ‚čÜőĪ i) = MŠīį.őĪŠīį .nIsoŠīį _ .secŠīį i
      elim-hom ő∑ = MŠīį.ő∑Šīį‚ü® _ ‚ü©
      elim-hom (ő∑-nat f i) = MŠīį.ő∑Šīį .transŠīį .N-homŠīį (elim-hom f) i
      elim-hom ő∑‚ĀĽ = MŠīį.ő∑Šīį .nIsoŠīį _ .invŠīį
      elim-hom (ő∑‚čÜő∑‚ĀĽ i) = MŠīį.ő∑Šīį .nIsoŠīį _ .retŠīį i
      elim-hom (ő∑‚ĀĽ‚čÜő∑ i) = MŠīį.ő∑Šīį .nIsoŠīį _ .secŠīį i
      elim-hom ŌĀ = MŠīį.ŌĀŠīį‚ü® _ ‚ü©
      elim-hom (ŌĀ-nat f i) = MŠīį.ŌĀŠīį .transŠīį .N-homŠīį (elim-hom f) i
      elim-hom ŌĀ‚ĀĽ = MŠīį.ŌĀŠīį .nIsoŠīį _ .invŠīį
      elim-hom (ŌĀ‚čÜŌĀ‚ĀĽ i) = MŠīį.ŌĀŠīį .nIsoŠīį _ .retŠīį i
      elim-hom (ŌĀ‚ĀĽ‚čÜŌĀ i) = MŠīį.ŌĀŠīį .nIsoŠīį _ .secŠīį i
      elim-hom (pentagon i) = MŠīį.pentagonŠīį _ _ _ _ i
      elim-hom (triangle i) = MŠīį.triangleŠīį _ _ i

      elim : GlobalSection MŠīį.CŠīį
      elim .F-obŠīį = elim-ob
      elim .F-homŠīį = elim-hom
      elim .F-idŠīį = refl
      elim .F-seqŠīį _ _ = refl

  module _ (M : MonoidalCategory ‚ĄďC ‚ĄďC') where
    private
      module M = MonoidalCategory M
    module _ (ńĪ : X ‚Üí M.C .ob) where
      private
        MŠīį = weaken FreeMonoidalCategory M
        module MŠīį = MonoidalCategoryŠīį MŠīį
      open StrongMonoidalFunctor
      open StrongMonoidalStr
      open LaxMonoidalStr
      -- TODO: we can probably show that elim is a "strong monoidal
      -- section" and then get this out as a general principle but we
      -- haven't needed strong monoidal sections for anything
      -- else so far so I'll just do this manually
      rec : StrongMonoidalFunctor FreeMonoidalCategory M
      rec .F = Wk.introS‚ĀĽ (elim MŠīį ńĪ)
      rec .strmonstr .laxmonstr .őĶ = M.id
      rec .strmonstr .laxmonstr .őľ .N-ob x = M.id
      rec .strmonstr .laxmonstr .őľ .N-hom f =
        M.‚čÜIdR _ ‚ąô sym (M.‚čÜIdL _)
      rec .strmonstr .laxmonstr .őĪőľ-law x y z =
        M.‚čÜIdR _
        ‚ąô cong‚āā M._‚čÜ_ refl (M.‚ĒÄ‚äó‚ĒÄ .F-id)
        ‚ąô M.‚čÜIdR _ ‚ąô sym (M.‚čÜIdL _)
        ‚ąô cong‚āā M._‚čÜ_ (sym (M.‚ĒÄ‚äó‚ĒÄ .F-id)) refl
        ‚ąô cong‚āā M._‚čÜ_ (sym (M.‚čÜIdR _)) refl
      rec .strmonstr .laxmonstr .ő∑őĶ-law x =
        cong‚āā M._‚čÜ_ (M.‚čÜIdR _ ‚ąô M.‚ĒÄ‚äó‚ĒÄ .F-id) refl ‚ąô M.‚čÜIdL _
      rec .strmonstr .laxmonstr .ŌĀőĶ-law x =
        cong‚āā M._‚čÜ_ (M.‚čÜIdR _ ‚ąô M.‚ĒÄ‚äó‚ĒÄ .F-id) refl ‚ąô M.‚čÜIdL _
      rec .strmonstr .őĶ-isIso = idCatIso .snd
      rec .strmonstr .őľ-isIso _ = idCatIso .snd

    module _ (G H : StrongMonoidalFunctor FreeMonoidalCategory M) where
      private
        module G = StrongMonoidalFunctor G
        module H = StrongMonoidalFunctor H
      uniq : ‚ąÄ (ńĪ‚ČÖ : ‚ąÄ x ‚Üí CatIso M.C (G.F ‚üÖ ‚ÜĎ x ‚üÜ ) (H.F ‚üÖ ‚ÜĎ x ‚üÜ ))
        ‚Üí G.F ‚ČÖŠ∂ú H.F
      uniq ńĪ‚ČÖ = IsoReflection (GlobalSectionReindex‚ÜíSection _ _
        (elim (IsoComma G H) ńĪ‚ČÖ))

  module _
